# NEXAI Proxy Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Exchange to use: binance | mexc
EXCHANGE=binance

# Binance API credentials (create at https://www.binance.com/en/my/settings/api-management)
# REQUIRED for real Binance order placement
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# MEXC API credentials (create at https://www.mexc.com/user/openapi)
# Only needed if EXCHANGE=mexc
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET=your_mexc_secret_here

# Webhook shared secret — set the same value in NEXAI connector panel
# Used to verify that signals come from YOUR NEXAI dashboard (HMAC-SHA256)
# Leave blank to skip signature verification (not recommended)
WEBHOOK_SECRET=change_this_to_a_random_secret_string

# Proxy server port (default 3000)
PORT=3000
